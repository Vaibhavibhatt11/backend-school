{
  "module": "Parent Portal",
  "description": "All APIs for the parent-facing app. Parent must be logged in with role PARENT. Most endpoints require a `childId` query param and will only return data for students linked to that parent (IDOR prevention via StudentParent).",
  "dataSource": "All parent data is created and managed on the admin side (School Admin, Staff, Accountant, etc.). Parent APIs expose read-only student/child data plus limited settings updates.",
  "baseUrl": "https://backend-school-app.onrender.com/api/v1",
  "totalEndpoints": 17,
  "submodules": {
    "Children": ["GET /parent/children"],
    "Home": ["GET /parent/home"],
    "Announcements": ["GET /parent/announcements"],
    "Notifications": ["GET /parent/notifications"],
    "Attendance": ["GET /parent/attendance"],
    "Fees": ["GET /parent/fees", "GET /parent/invoices/:invoiceId"],
    "Timetable": ["GET /parent/timetable"],
    "Progress Reports": ["GET /parent/progress-reports"],
    "Live Classes": ["GET /parent/live-classes"],
    "Profile Hub": ["GET /parent/profile-hub"],
    "Library": ["GET /parent/library"],
    "Documents": ["GET /parent/documents"],
    "AI Assistant (stub)": ["POST /parent/ai/ask", "GET /parent/ai/career"],
    "Settings": ["GET /parent/settings", "PUT /parent/settings"]
  },
  "auth": {
    "type": "Bearer",
    "header": "Authorization",
    "value": "Bearer <accessToken>",
    "note": "Use token from POST /auth/login. Role must be PARENT. Missing/invalid token returns 401."
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/parent/children",
      "description": "List the children/students linked to the logged-in parent.",
      "query": {},
      "body": null,
      "response": {
        "success": true,
        "data": {
          "children": [
            { "id": "string", "name": "string", "grade": "string", "active": "boolean" }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/home",
      "description": "Parent home summary for a selected child (dashboard-like).",
      "query": { "childId": "string (required)", "month": "string (YYYY-MM, optional)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "childName": "string",
          "childGrade": "string",
          "attendance": "number",
          "feesDue": "number",
          "feesDueDate": "string | null",
          "upcomingClass": "string | null",
          "classStartIn": "string | null",
          "recentNotices": [
            {
              "type": "urgent | teacher",
              "title": "string",
              "description": "string",
              "postedBy": "string",
              "time": "string | null",
              "urgent": "boolean",
              "teacherName": "string | null",
              "teacherClass": "string | null"
            }
          ],
          "subjectScores": { "string": "number" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/announcements",
      "description": "Announcements/notice board list for a child. Optional filter by type.",
      "query": { "childId": "string (required)", "type": "string (optional: urgent|teacher|all)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "announcements": [
            {
              "type": "urgent | teacher",
              "title": "string",
              "description": "string",
              "postedBy": "string",
              "time": "string | null",
              "urgent": "boolean",
              "teacherName": "string | null",
              "teacherClass": "string | null",
              "attachment": "string | null"
            }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/notifications",
      "description": "Notifications grouped into Today/Yesterday/Last Week.",
      "query": { "childId": "string (required)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "notifications": [
            {
              "section": "string",
              "items": [
                {
                  "type": "string",
                  "title": "string",
                  "description": "string",
                  "time": "string | null",
                  "unread": "boolean",
                  "action": "string | null"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/attendance",
      "description": "Attendance calendar for the selected child. Month defaults to current month.",
      "query": { "childId": "string (required)", "month": "string (YYYY-MM, optional)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "calendarDays": ["number | null (35 slots)"],
          "attendanceStats": { "present": "number", "absent": "number", "late": "number" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/fees",
      "description": "Fees summary for the selected child (pending and overdue invoices).",
      "query": { "childId": "string (required)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "totalOutstanding": "number",
          "invoices": [
            { "id": "string", "title": "string", "subtitle": "string | null", "amount": "number", "dueDate": "string | null", "type": "pending | overdue" }
          ],
          "overdueInvoices": [
            { "id": "string", "title": "string", "subtitle": "string | null", "amount": "number", "dueDate": "string | null", "type": "pending | overdue" }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/invoices/:invoiceId",
      "description": "Invoice detail + payment history. Parent is enforced via StudentParent scoping.",
      "query": {},
      "body": null,
      "response": {
        "success": true,
        "data": {
          "invoice": "object",
          "paymentHistory": [
            { "ref": "string", "amount": "number", "date": "string | null", "time": "string | null", "method": "string | null" }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/timetable",
      "description": "Daily timetable for a child (contract-ready from live sessions).",
      "query": { "childId": "string (required)", "day": "number (1-31, optional; defaults to current day)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "items": [
            { "time": "string", "subject": "string", "teacher": "string | null", "room": "string | null", "period": "string", "isLive": "boolean" }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/progress-reports",
      "description": "Progress summary (placeholder aggregation from exam results + fee history).",
      "query": { "childId": "string (required)", "term": "string (optional)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "studentName": "string",
          "studentClass": "string",
          "academicYear": "string",
          "selectedTerm": "string",
          "gpa": "number",
          "subjectScores": { "string": "number" },
          "attendance": { "present": "number", "absent": "number", "late": "number" },
          "feeHistory": ["number (last 5 months)"]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/live-classes",
      "description": "Live class overview for a child (current session and upcoming list).",
      "query": { "childId": "string (required)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "liveClass": { "title": "string", "teacher": "string | null", "time": "string (ISO)" },
          "upcomingClasses": [
            { "title": "string", "teacher": "string | null", "time": "string (ISO)", "room": "string | null", "subject": "string", "isLive": "boolean" }
          ]
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/profile-hub",
      "description": "Child profile hub (student info + related parents + placeholders).",
      "query": { "childId": "string (required)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "studentName": "string",
          "studentClass": "string",
          "dob": "string (ISO) | null",
          "bloodGroup": "string | null",
          "fatherName": "string | null",
          "motherName": "string | null",
          "medicalInfo": "object | null",
          "academicYear": "string",
          "currentTermPercentage": "number | null",
          "classAvg": "number | null",
          "subjectScores": { "string": "number" },
          "documents": "array (currently empty)"
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/library",
      "description": "Library search + active loans.",
      "query": { "childId": "string (required)", "page": "number", "limit": "number (max 100)", "search": "string (optional)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "search": "string",
          "recommendedBooks": [
            { "id": "string", "title": "string", "author": "string | null", "category": "string | null", "availableCopies": "number" }
          ],
          "activeLoans": [
            { "id": "string", "title": "string", "author": "string | null", "dueDate": "string (ISO) | null", "status": "string" }
          ],
          "pagination": { "page": "number", "limit": "number", "total": "number", "totalPages": "number" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/parent/documents",
      "description": "Documents list with pagination.",
      "query": { "childId": "string (required)", "page": "number", "limit": "number (max 100)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "documents": [
            { "id": "string", "name": "string", "url": "string", "type": "string", "status": "AVAILABLE", "sizeKb": "number | null", "createdAt": "string (ISO)" }
          ],
          "pagination": { "currentPage": "number", "totalPages": "number" }
        }
      }
    },
    {
      "method": "POST",
      "path": "/parent/ai/ask",
      "description": "AI assistant ask (stub).",
      "query": {},
      "body": { "question": "string (required)" },
      "response": { "success": true, "data": { "answer": "string" } }
    },
    {
      "method": "GET",
      "path": "/parent/ai/career",
      "description": "AI career suggestions (stub).",
      "query": {},
      "body": null,
      "response": { "success": true, "data": { "suggestions": ["array"] } }
    },
    {
      "method": "GET",
      "path": "/parent/settings",
      "description": "Parent-linked child settings/preferences.",
      "query": { "childId": "string (required)" },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "preferences": "object",
          "pushNotificationsEnabled": "boolean",
          "faceIdEnabled": "boolean",
          "selectedLanguage": "string",
          "darkModeOption": "string"
        }
      }
    },
    {
      "method": "PUT",
      "path": "/parent/settings",
      "description": "Update child settings/preferences.",
      "query": { "childId": "string (required)" },
      "body": { "preferences": "object (max size enforced)" },
      "response": { "success": true, "data": { "studentId": "string", "preferences": "object" } }
    }
  ],
  "notes": {
    "paginationCaps": "List endpoints using page/limit enforce limit max 100.",
    "security": "All student queries are scoped by resolving the child via StudentParent linked to the logged-in parent."
  }
}

