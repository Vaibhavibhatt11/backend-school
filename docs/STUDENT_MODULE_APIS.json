      "response": {
        "success": true,
        "data": {
          "id": "string",
          "homeworkId": "string",
          "studentId": "string",
          "url": "string | null",
          "fileUrls": "string[]",
          "status": "string",
          "submittedAt": "string (ISO)"
        }
      }
    },
