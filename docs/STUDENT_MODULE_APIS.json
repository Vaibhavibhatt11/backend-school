  "authEndpoint": {
    "method": "POST",
    "path": "/auth/login",
    "description": "Login to get accessToken. Use email/password. For student app, user must have role STUDENT and linked Student profile.",
    "body": { "email": "string", "password": "string" },
    "response": {
      "success": true,
      "data": {
        "accessToken": "string",
        "refreshToken": "string",
        "user": { "id": "string", "fullName": "string", "email": "string", "role": "STUDENT", "schoolId": "string" }
      }
    }
  },
  "refreshToken": {
    "method": "POST",
    "path": "/auth/refresh",
    "body": { "refreshToken": "string" },
    "response": { "success": true, "data": { "accessToken": "string", "refreshToken": "string" } }
  },
  "errorResponse": {
    "success": false,
    "error": "string (message)",
    "errorCode": "string (optional)"
  },
  "notes": [
    "Base URL: https://backend-school-app.onrender.com/api/v1",
    "All /student/* routes require header: Authorization: Bearer <accessToken>",
    "User role must be STUDENT; Student profile must be linked (userId on Student)",
    "Pagination: page (1-based), limit (default 20, max 100). List responses include data.pagination: { page, limit, total, totalPages }",
    "Success: every API returns { success: true, data: ... }. Errors return { success: false, error: \"message\" } with 4xx/5xx status",
    "GET /student/transport returns data: null when student has no transport allocation",
    "Performance: dashboard, profile, timetable, and exams use server-side caching for fast responses; list endpoints use batched DB queries and capped result sizes"
  ],
  "databaseAndScale": {
    "indexes": "StudentAttendance (studentId, date), ExamResult (studentId, createdAt), Homework (schoolId, classId, isPublished), plus existing Invoice/Payment/Event indexes for fast student queries.",
    "connectionPool": "Use single Prisma client per process; set DATABASE_URL with ?connection_limit=N (e.g. 20–50) in production.",
    "caching": "Redis recommended; CACHE_ENABLED=true. Dashboard, profile, timetable, exams cached for quick response under load.",
    "readiness": "GET /api/v1/ready checks DB and Redis; use for load balancer health.",
    "seeAlso": "backend/docs/SCALING_AND_RELIABILITY.md for 1M+ user checklist."
  },
  "security": {
    "authentication": "All routes require valid JWT (Bearer). Missing or invalid token returns 401 Unauthorized.",
    "authorization": "User must have role STUDENT and a linked Student profile; otherwise 403 Forbidden.",
    "dataIsolation": "Every query is scoped by schoolId and studentId so students only access their own data.",
    "inputValidation": "IDs (params) validated format/length; request body validated and sanitized (max lengths, required fields). Invalid input returns 400 with errorCode INVALID_INPUT.",
    "limits": "reason 2000 chars, purpose 500, question 2000, preferences 10KB, fileUrls max 20 items, search 100 chars, month YYYY-MM.",
    "idorPrevention": "Resource IDs (homework, exam, event, payment) validated; access always checked against logged-in student/school."
  },
  "exampleSuccess": { "success": true, "data": { "items": [], "pagination": { "page": 1, "limit": 20, "total": 0, "totalPages": 0 } } },
  "exampleError": { "success": false, "error": "Homework not found" }
}
