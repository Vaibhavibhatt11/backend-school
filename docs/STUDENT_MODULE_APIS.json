{
  "module": "Student Portal",
  "description": "All APIs for the student-facing app. User must be logged in with role STUDENT and have a linked Student profile. Every endpoint returns { success: true, data: ... } on success.",
  "dataSource": "All student data is created and managed on the admin side (School Admin, Staff, Accountant, etc.). Student APIs only expose that data to the logged-in student—read-only for most resources; students can submit homework, register for events, request leave, and update limited profile/settings.",
  "baseUrl": "https://backend-school-app.onrender.com/api/v1",
  "totalEndpoints": 35,
  "submodules": {
    "Dashboard": ["GET /student/dashboard"],
    "Profile": ["GET /student/profile", "PUT /student/profile"],
    "Timetable": ["GET /student/timetable"],
    "Attendance": ["GET /student/attendance"],
    "Homework": ["GET /student/homework", "GET /student/homework/:id", "POST /student/homework/:id/submit"],
    "Study Materials": ["GET /student/study-materials"],
    "Exams": ["GET /student/exams", "GET /student/exams/:id/result", "GET /student/exam-timetable"],
    "Fees": ["GET /student/fees", "GET /student/fees/receipts", "GET /student/payments/:id/receipt"],
    "Announcements": ["GET /student/announcements"],
    "Notifications": ["GET /student/notifications"],
    "Circulars": ["GET /student/circulars"],
    "Events": ["GET /student/events", "POST /student/events/:id/register"],
    "Transport": ["GET /student/transport"],
    "Library": ["GET /student/library", "GET /student/library/books"],
    "Achievements": ["GET /student/achievements"],
    "Leave Requests": ["GET /student/leave-requests", "POST /student/leave-requests"],
    "Subject Teachers": ["GET /student/subject-teachers"],
    "Meetings": ["POST /student/meetings/request"],
    "Settings": ["GET /student/settings", "PUT /student/settings"],
    "Health": ["GET /student/health"],
    "Report Cards": ["GET /student/report-cards"],
    "Documents": ["GET /student/documents"],
    "AI (stub)": ["POST /student/ai/ask", "GET /student/ai/career"]
  },
  "auth": {
    "type": "Bearer",
    "header": "Authorization",
    "value": "Bearer <accessToken>",
    "note": "Use token from POST /auth/login. Role must be STUDENT."
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/student/dashboard",
      "description": "Student dashboard: attendance summary (last 30 days), upcoming exams (5), pending dues count, announcements count.",
      "query": {},
      "body": null,
      "response": {
        "success": true,
        "data": {
          "studentId": "string",
          "attendanceSummary": { "PRESENT": "number", "ABSENT": "number", "LATE": "number", "LEAVE": "number" },
          "upcomingExams": [{ "id": "string", "name": "string", "examDate": "string (ISO)", "subjectId": "string" }],
          "pendingDuesCount": "number",
          "announcementsCount": "number"
        }
      }
    },
    {
      "method": "GET",
      "path": "/student/profile",
      "description": "Logged-in student's full profile with parents and class.",
      "query": {},
      "body": null,
      "response": {
        "success": true,
        "data": {
          "id": "string",
          "admissionNo": "string",
          "firstName": "string",
          "lastName": "string",
          "dob": "string (ISO) | null",
          "gender": "string | null",
          "className": "string",
          "section": "string | null",
          "rollNo": "number | null",
          "status": "ACTIVE | INACTIVE",
          "guardianPhone": "string | null",
          "createdAt": "string (ISO)",
          "parents": [{ "relationType": "string", "isPrimary": "boolean", "parent": { "id": "string", "fullName": "string", "email": "string | null", "phone": "string | null" } }],
          "class": { "id": "string", "name": "string", "section": "string" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/student/timetable",
      "description": "Own class timetable (upcoming live sessions for student's class).",
      "query": {},
      "body": null,
      "response": {
        "success": true,
        "data": {
          "slots": [{ "id": "string", "title": "string", "startsAt": "string (ISO)", "endsAt": "string (ISO) or null", "subject": { "id": "string", "name": "string" } }]
        }
      }
    },
    {
      "method": "GET",
      "path": "/student/attendance",
      "description": "Own attendance records with pagination. Optional filter by month.",
      "query": {
        "page": "number (default 1)",
        "limit": "number (default 20, max 100)",
        "month": "string (YYYY-MM) optional"
      },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "items": [{ "id": "string", "date": "string (ISO)", "status": "PRESENT | ABSENT | LATE | LEAVE", "remark": "string | null" }],
          "pagination": { "page": "number", "limit": "number", "total": "number", "totalPages": "number" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/student/homework",
      "description": "Homework list for student's class with own submission status per homework.",
      "query": {
        "page": "number (default 1)",
        "limit": "number (default 20, max 100)"
      },
      "body": null,
      "response": {
        "success": true,
        "data": {
          "items": [{ "id": "string", "title": "string", "dueDate": "string (ISO)", "classId": "string | null", "subjectId": "string | null", "submissions": [{ "id": "string", "status": "string", "submittedAt": "string (ISO)" }] }],
          "pagination": { "page": "number", "limit": "number", "total": "number", "totalPages": "number" }
        }
      }
    },
