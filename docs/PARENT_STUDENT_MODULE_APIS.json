  "unifiedAppModuleNote": {
    "path": "/api/v1/app",
    "allowedRolesOnly": ["STUDENT", "PARENT"],
    "description": "Same two roles only: JWT must be STUDENT or PARENT. Optional shared dashboard slice (children, dashboard, attendance, fees, announcements). Endpoints not duplicated here; see FRONTEND_TEAM_API.json if needed."
  },
  "checklistForFrontend": [
    "JWT role claim must be STUDENT for /student/* and PARENT for /parent/* only — no other roles.",
    "Store access token securely; send Authorization header on every request.",
    "Parent: load GET /parent/children, persist selected childId for subsequent calls.",
    "Parent: append childId as query string for all routes that require it (see requiresChildId: true).",
    "Handle 401 (refresh or re-login), 400 CHILD_ID_REQUIRED, 403 FORBIDDEN (wrong role or access), 404 for wrong child/invoice.",
    "Use HTTPS base URL in production."
  ]
