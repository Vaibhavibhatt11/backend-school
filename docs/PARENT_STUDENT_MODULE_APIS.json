    "parent": {
      "allowedRole": "PARENT",
      "role": "PARENT",
      "description": "Logged-in parent only (role must be PARENT, not STUDENT or any staff role). Most child-specific routes require query param childId (linked student id). Invoice detail uses path id only — ownership verified server-side.",
      "endpoints": [
        {
          "name": "List linked children",
          "method": "GET",
          "path": "/api/v1/parent/children",
          "requiresChildId": false,
          "query": {},
          "body": null,
          "notes": "Call first to obtain ids for childId on other routes."
        },
        {
          "name": "Home / summary",
          "method": "GET",
          "path": "/api/v1/parent/home",
