{
  "$comment": "Frontend handoff: Student + Parent mobile/portal APIs only. All paths are under apiPrefix.",
  "meta": {
    "title": "Parent & Student module — API reference",
    "apiVersion": "v1",
    "baseUrlProduction": "https://backend-school-app.onrender.com",
    "baseUrlLocal": "http://localhost:3000",
    "apiPrefix": "/api/v1",
    "studentBasePath": "/api/v1/student",
    "parentBasePath": "/api/v1/parent",
    "roles": {
      "allowedRoles": ["STUDENT", "PARENT"],
      "rule": "This module uses exactly two role values. No other roles apply to these routes.",
      "mapping": {
        "STUDENT": "Required for every /api/v1/student/* request (JWT role claim must be STUDENT only).",
        "PARENT": "Required for every /api/v1/parent/* request (JWT role claim must be PARENT only)."
      },
      "notAllowed": "Tokens with any other role (e.g. SCHOOLADMIN, SUPERADMIN, HR, ACCOUNTANT) must not be used for /student or /parent — the API returns 403."
    },
    "authentication": {
      "type": "JWT Bearer",
      "header": "Authorization: Bearer <access_token>",
      "login": "POST /api/v1/auth/login — user must have role exactly STUDENT or exactly PARENT (one role per account for this app).",
      "refresh": "POST /api/v1/auth/refresh",
      "note": "Every endpoint below requires a valid access token. Exactly one role per route group: /student/* accepts STUDENT only; /parent/* accepts PARENT only."
    },
    "responseEnvelope": {
      "success": true,
      "data": "{ ... }",
      "onError": "{ success: false, error: string, errorCode?: string }"
    },
    "parentChildScoping": {
      "childId": "Required query param on most Parent routes (student id). Must be one of the parent’s linked children — server validates via StudentParent (IDOR protection).",
      "errorIfMissing": "CHILD_ID_REQUIRED (400)",
      "listChildrenFirst": "GET /api/v1/parent/children returns { data: { children: [{ id, name, grade, active }] } } — use child id as childId."
    },
    "idFormat": "Path ids (homework, exam, payment, invoice) must match server validation: alphanumeric, hyphen, underscore; typically 15–50 chars (cuid/uuid)."
  },
  "modules": {
    "student": {
