// ----- Admissions -----
enum AdmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAITING
  ONBOARDED
}

model AdmissionApplication {
  id            String          @id @default(cuid())
  schoolId      String
  applicationNo String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  dob           DateTime?
  gender        String?
  appliedClass   String
  appliedSection String?
  status        AdmissionStatus @default(SUBMITTED)
  admissionFeePaid Boolean       @default(false)
  registrationNo  String?
  studentId     String?
  meta          Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  documents AdmissionDocument[]

  @@unique([schoolId, applicationNo])
  @@index([schoolId, status])
}

model AdmissionDocument {
  id         String   @id @default(cuid())
  applicationId String
  name       String
  url        String
  type       String
  createdAt  DateTime @default(now())

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

