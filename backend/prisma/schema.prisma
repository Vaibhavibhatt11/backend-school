  subject     Subject?   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  lessonPlans LessonPlan[]

  @@index([schoolId, classId, subjectId])
}

model LessonPlan {
  id         String   @id @default(cuid())
  schoolId   String
  subjectId  String?
  syllabusId String?
  title      String
  date       DateTime
  duration   Int?     @default(45)
