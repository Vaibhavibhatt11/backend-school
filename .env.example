NODE_ENV=development
PORT=5000

# PostgreSQL — use your own URL (Render internal URL on Render, or local Docker)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

JWT_ACCESS_SECRET="replace_with_min_16_char_secret"
JWT_REFRESH_SECRET="replace_with_min_16_char_secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
PASSWORD_RESET_SECRET="replace_with_min_16_char_secret"
PASSWORD_RESET_TOKEN_EXPIRES_IN="10m"
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10
PUBLIC_BASE_URL="https://your-public-domain-or-ngrok-url"
CORS_ORIGIN="http://localhost:5173"
TRUST_PROXY=1
SWAGGER_ENABLED="true"
REQUEST_BODY_LIMIT="2mb"
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_USE_REDIS="false"
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_PER_IP=300
API_RATE_LIMIT_USE_REDIS="true"
HEALTHCHECK_DB_TIMEOUT_MS=2000
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=120000

# Optional — distributed rate limit + cache (omit or leave empty if not using Redis)
REDIS_URL=""

# Cache (requires Redis when CACHE_ENABLED=true)
CACHE_ENABLED="true"
CACHE_TTL_DASHBOARD_SEC=90
CACHE_TTL_PROFILE_SEC=300
CACHE_TTL_ME_SEC=120
CACHE_TTL_PERMISSIONS_SEC=3600
CACHE_KEY_PREFIX="se:cache:"

# SMTP (optional in dev; needed for real password reset emails in production)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="your-email@gmail.com"
